---
import Admin from '../../../layouts/Admin.astro';
import { listPieces } from '../../../lib/admin-data';

export const prerender = false;

const pieces = await listPieces();
const saved = Astro.url.searchParams.get('saved');
---

<Admin title="Pieces" active="pieces">
  <h1>Pieces</h1>
  <p class="lede">{pieces.length} cataloged. Public pieces appear in the gallery and catalog after the next publish rebuild.</p>
  {saved === 'deleted' && <p class="notice muted">Piece deleted.</p>}

  <div class="btnrow" style="margin-top:28px;">
    <a class="btn primary" href="/admin/intake">New Piece via Intake</a>
    <a class="btn" href="/admin/pieces/new">New Piece (Manual)</a>
  </div>

  <table class="list">
    <thead>
      <tr><th>Accession</th><th>Title</th><th>Type</th><th>Room</th><th>Images</th><th>Status</th></tr>
    </thead>
    <tbody>
      {
        pieces.map((p) => (
          <tr>
            <td class="num"><a href={`/admin/pieces/${p.id}`}>{p.accession}</a></td>
            <td><a href={`/admin/pieces/${p.id}`}>{p.title}</a></td>
            <td>{p.objectType}</td>
            <td>{p.roomNumeral ? `Room ${p.roomNumeral}${p.roomOrder != null ? ` · ${p.roomOrder}` : ''}` : 'Unplaced'}</td>
            <td class="num">{p.imageCount}</td>
            <td><span class={`pill${p.isPublic ? ' on' : ''}`}>{p.isPublic ? 'Public' : 'Draft'}</span></td>
          </tr>
        ))
      }
    </tbody>
  </table>
</Admin>
